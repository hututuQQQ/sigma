{
  "name": "agent-tui",
  "version": "3.0.0-beta.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --experimental-ffi --disable-warning=ExperimentalWarning dist/index.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@opentui/core": "0.4.3",
    "agent-presentation": "workspace:*",
    "agent-protocol": "workspace:*",
    "web-tree-sitter": "0.25.10"
  },
  "engines": { "node": ">=26.4.0" }
}
