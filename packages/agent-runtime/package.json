{
  "name": "agent-runtime",
  "version": "4.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./session-admin": { "types": "./dist/session-admin.d.ts", "default": "./dist/session-admin.js" },
    "./testing": { "types": "./dist/testing.d.ts", "default": "./dist/testing.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "agent-checkpoint": "workspace:*",
    "agent-code-intel": "workspace:*",
    "agent-config": "workspace:*",
    "agent-context": "workspace:*",
    "agent-execution": "workspace:*",
    "agent-extensions": "workspace:*",
    "agent-kernel": "workspace:*",
    "agent-mcp": "workspace:*",
    "agent-model": "workspace:*",
    "agent-platform": "workspace:*",
    "agent-protocol": "workspace:*",
    "agent-store": "workspace:*",
    "agent-supervisor": "workspace:*",
    "agent-tools": "workspace:*"
  },
  "engines": { "node": ">=26.4.0" }
}
