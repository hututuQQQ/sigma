{
  "name": "agent-cli",
  "version": "3.0.0-beta.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:tui": "node --experimental-ffi --disable-warning=ExperimentalWarning dist/index.js tui",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "agent-code-intel": "workspace:*",
    "agent-config": "workspace:*",
    "agent-execution": "workspace:*",
    "agent-extensions": "workspace:*",
    "agent-presentation": "workspace:*",
    "agent-protocol": "workspace:*",
    "agent-runtime": "workspace:*",
    "agent-store": "workspace:*",
    "agent-tui": "workspace:*",
    "smol-toml": "^1.7.0"
  },
  "engines": { "node": ">=26.4.0" }
}
