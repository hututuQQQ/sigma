{
  "name": "agent-code-intel",
  "version": "3.0.0-rc.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').copyFileSync('src/typescript-server.mjs','dist/typescript-server.mjs')\"",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "agent-execution": "workspace:*",
    "pyright": "1.1.411",
    "typescript": "5.9.3"
  },
  "engines": { "node": ">=26.4.0" }
}
