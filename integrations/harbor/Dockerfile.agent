ARG AGENT_TARGET_ARCH=x64

FROM debian:bookworm-slim

ARG AGENT_TARGET_ARCH

RUN apt-get update \
  && apt-get install -y --no-install-recommends bash ca-certificates gzip python3 tar \
  && rm -rf /var/lib/apt/lists/*

COPY .artifacts/agent-cli-linux-${AGENT_TARGET_ARCH}.tgz /tmp/agent-cli.tgz

RUN mkdir -p /opt/agent-cli \
  && tar -xzf /tmp/agent-cli.tgz -C /opt/agent-cli --strip-components=1 \
  && chmod +x /opt/agent-cli/bin/agent \
  && if [ -f /opt/agent-cli/bin/node ]; then chmod +x /opt/agent-cli/bin/node; fi \
  && ln -sf /opt/agent-cli/bin/agent /usr/local/bin/agent \
  && /usr/local/bin/agent --help >/dev/null
