          { "type": "git_diff", "requireClean": true }
        ]
      }
    },
    {
      "schemaVersion": 1,
      "id": "steer-cleanup",
      "title": "Honor a mid-run steer and clean abandoned work",
      "suites": ["quick", "experience"],
      "fixture": { "workspace": "scenarios/steer-cleanup/workspace" },
      "userMessages": [
        "新建 draft.md，写一份至少六段的发布公告草稿。"
      ],
      "surface": "tui",
      "permissionPolicy": "allow_once",
      "expectedTerminal": "completed",
      "budget": "small",
      "allowedChanges": [
        "draft.md"
      ],
      "interactions": [
        {
          "triggers": [
            { "kind": "first_mutation" }
          ],
          "action": "steer",
          "text": "停止刚才的任务。清理这次任务产生的所有临时改动，让工作区恢复到开始前的状态，然后确认已经停止。"
        }
      ],
      "verifier": {
        "checks": [
          {
            "type": "command",
            "argv": ["node", "$MANIFEST_DIR/_shared/verify-workspace.mjs", "$WORKSPACE", "$MANIFEST_DIR/scenarios/steer-cleanup/verifier.json"],
            "expectedExitCode": 0
          },
          { "type": "answer", "pattern": "(?:stopp?ed|clean|revert|已停止|清理|恢复)", "flags": "iu", "minMatches": 1 },
          { "type": "git_diff", "requireClean": true }
        ]
      }
    },
