            "type": "command",
            "argv": ["node", "$MANIFEST_DIR/_shared/verify-workspace.mjs", "$WORKSPACE", "$MANIFEST_DIR/scenarios/validation-failure-honesty/verifier.json"],
            "expectedExitCode": 0
          },
          { "type": "command", "argv": ["node", "check.mjs"], "expectedExitCode": 1 },
