{
  "schemaVersion": 1,
  "scenarios": [
    {
      "schemaVersion": 1,
      "id": "line-count-readonly",
      "title": "Scoped source line count without workspace mutation",
      "suites": ["quick", "experience"],
      "fixture": { "workspace": "scenarios/line-count-readonly/workspace" },
      "userMessages": [
        "请统计 src 和 tests 目录中所有 .js 与 .ts 文件的非空行数。分别列出每个文件的行数和总计，不要修改任何文件。"
      ],
      "surface": "tui",
      "permissionPolicy": "auto",
      "expectedTerminal": "completed",
      "budget": "tiny",
      "allowedChanges": [],
      "interactions": [],
      "verifier": {
        "checks": [
          {
            "type": "command",
            "argv": ["node", "$MANIFEST_DIR/_shared/verify-workspace.mjs", "$WORKSPACE", "$MANIFEST_DIR/scenarios/line-count-readonly/verifier.json"],
            "expectedExitCode": 0,
            "timeoutMs": 10000
          },
          { "type": "answer", "pattern": "counter\\.js[^\\n]*3", "minMatches": 1 },
          { "type": "answer", "pattern": "constants\\.ts[^\\n]*2", "minMatches": 1 },
          { "type": "answer", "pattern": "counter\\.test\\.js[^\\n]*6", "minMatches": 1 },
          { "type": "answer", "pattern": "(?:total|总计|合计)[^\\n]*11", "flags": "iu", "minMatches": 1 },
          { "type": "git_diff", "requireClean": true }
        ]
      }
    },
    {
      "schemaVersion": 1,
      "id": "single-file-edit",
      "title": "Small exact edit constrained to one file",
      "suites": ["quick", "experience"],
      "fixture": { "workspace": "scenarios/single-file-edit/workspace" },
      "userMessages": [
        "把 config.json 里的 theme 从 light 改成 dark，其他配置和文件都不要改。完成后说明改了什么。"
      ],
      "surface": "cli",
      "permissionPolicy": "auto",
      "expectedTerminal": "completed",
      "budget": "small",
      "allowedChanges": ["config.json"],
      "interactions": [],
      "verifier": {
        "checks": [
          {
            "type": "command",
            "argv": ["node", "$MANIFEST_DIR/_shared/verify-workspace.mjs", "$WORKSPACE", "$MANIFEST_DIR/scenarios/single-file-edit/verifier.json"],
            "expectedExitCode": 0
          },
          { "type": "file", "path": "config.json", "contains": "\"theme\": \"dark\"" },
          { "type": "git_diff", "allowedPaths": ["config.json"] }
        ]
      }
    },
    {
