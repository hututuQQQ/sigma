    {
      "schemaVersion": 1,
      "id": "ambiguity-one-question",
      "title": "Ask one focused question for a material ambiguity",
      "suites": ["quick", "experience"],
      "fixture": { "workspace": "scenarios/ambiguity-one-question/workspace" },
      "userMessages": [
        "请把 settings.json 里的 timeout 调整成线上要使用的值。"
      ],
      "surface": "cli",
      "permissionPolicy": "auto",
      "expectedTerminal": "needs_input",
      "budget": "tiny",
      "allowedChanges": [],
      "interactions": [],
      "verifier": {
        "checks": [
          {
            "type": "command",
            "argv": ["node", "$MANIFEST_DIR/_shared/verify-workspace.mjs", "$WORKSPACE", "$MANIFEST_DIR/scenarios/ambiguity-one-question/verifier.json"],
