{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "include": ["files", "dependencies", "unlisted", "binaries"],
  "ignoreBinaries": ["python", "taskkill.exe"],
  "ignoreDependencies": ["pyright", "@stryker-mutator/vitest-runner"],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.mjs",
        "scripts/**/*.ts",
        "stryker.*.conf.mjs",
        "vitest.mutation.*.config.ts",
        "tests/**/*.{ts,tsx}"
      ],
      "project": [
        "scripts/**/*.{mjs,ts}",
        "tests/**/*.{ts,tsx}",
        "*.{js,mjs,cjs,ts}"
      ]
    },
    "packages/*": {
      "entry": ["src/index.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
